# ── 데이터베이스 ──
DATABASE_URL=postgresql://kbo_user:kbo_password123@localhost:5432/kbo_predict

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── OpenAI API (https://platform.openai.com 에서 발급) ──
OPENAI_API_KEY=sk-xxxxxxxx

# ── Statiz 로그인 ──
STATIZ_USER=your_statiz_id
STATIZ_PASS=your_statiz_password

# ── 기상청 API ──
WEATHER_API_KEY=your_weather_api_key

# ── ML 모델 경로 ──
XGBOOST_ARTIFACT_PATH=app/ml/artifacts/kbo_xgb_v1.pkl
LSTM_ARTIFACT_PATH=app/ml/artifacts/kbo_lstm_v1.pt
CALIBRATOR_PATH=app/ml/artifacts/calibrator.pkl
MODEL_VERSION=v1.0-xgb+lstm

# ── 앱 설정 ──
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000
